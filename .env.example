# Copy to .env.local and fill in. Never commit the real .env.local.

# Where the SQLite DB lives. Default: ./data/app.db
DCM_DB_PATH=./data/app.db

# Where encrypted SSH keys & per-host secrets live. Default: ./data/keys
DCM_KEYS_DIR=./data/keys

# Cookie name for session
DCM_SESSION_COOKIE=dcm_session

# Cookie Secure flag. Defaults to true in production (NODE_ENV=production), false otherwise.
# Override with "true" / "false" when needed (e.g., serving HTTP on a trusted LAN).
# DCM_SECURE_COOKIES=true

# Set to "true" ONLY if behind a reverse proxy that overwrites X-Forwarded-For.
# Otherwise leave unset — accepting these headers without a trusted proxy lets an
# attacker spoof their source IP and bypass per-IP rate limits.
# DCM_TRUST_PROXY=false
